---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const cats = ['渲染管线', '引擎定制', '角色技术', '读渲染', 'AI 与认知', '音乐与生活'];
  return cats.map((cat) => ({ params: { cat } }));
}

const { cat } = Astro.params;
const posts = (await getCollection('posts', (p) => p.data.cat === cat))
  .sort((a, b) => +b.data.date - +a.data.date);
const fmt = (d: Date) => d.toISOString().slice(0, 10);
const CAT_SW: Record<string, string> = {
  '渲染管线': '--c-render', '引擎定制': '--c-engine', '角色技术': '--c-char',
  '读渲染': '--c-tool', 'AI 与认知': '--c-ai', '音乐与生活': '--c-life',
};
---
<Base title={cat}>
<main class="wrap reader">
  <a class="back mono" href="/">← 返回首页</a>
  <h1 class="rd-title">{cat}</h1>
  <div class="meta mono">
    <span class="sw" style={`background:var(${CAT_SW[cat]});`}></span>
    <span>专栏</span>
    {posts.length > 0 && <span>{posts.length} 篇</span>}
  </div>
  {posts.length === 0 ? (
    <p class="mono" style="color:var(--ink2);">这个专栏还在筹备中，第一篇正在路上。</p>
  ) : (
    <div class="posts" style="border-top:1px solid var(--line); max-width:800px;">
      {posts.map((p) => (
        <a class="post" href={`/posts/${p.id}/`}>
          <span class="sw" style={`background:var(${CAT_SW[p.data.cat]});`}></span>
          <span class="t">{p.data.title}</span>
          <span class="cat mono">{p.data.cat}</span>
          <span class="d mono">{fmt(p.data.date)} · {p.data.mins} min</span>
        </a>
      ))}
    </div>
  )}
</main>
</Base>
