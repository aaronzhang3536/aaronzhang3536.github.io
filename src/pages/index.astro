---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';
const posts = (await getCollection('posts')).sort((a, b) => +b.data.date - +a.data.date);
const latest = posts.slice(0, 5);
const counts: Record<string, number> = {};
for (const p of posts) counts[p.data.cat] = (counts[p.data.cat] || 0) + 1;
const cnt = (c: string, empty = '筹备中') => (counts[c] ? `${counts[c]} 篇` : empty);
const tagCounts: Record<string, number> = {};
for (const p of posts) for (const t of p.data.tags) tagCounts[t] = (tagCounts[t] || 0) + 1;
const tagList = Object.entries(tagCounts).sort((a, b) => b[1] - a[1]);
/* 时间线：GPU 轨道 = UE 剖析四个子方向占满一帧 16.67ms；异步轨 = 读渲染 / AI / 生活 */
const SUBS = ['渲染', '角色', '几何', '系统'];
const subCounts: Record<string, number> = {};
for (const p of posts) if (p.data.sub) subCounts[p.data.sub] = (subCounts[p.data.sub] || 0) + 1;
const ueTotal = (counts['UE 剖析'] || 0) || 1;
const pct = (s: string) => (((subCounts[s] || 0) / ueTotal) * 100).toFixed(1);
const ms = (s: string) => (((subCounts[s] || 0) / ueTotal) * 16.67).toFixed(1);
const ASYNCS: [string, string][] = [['读渲染', '--accent'], ['AI 与认知', '--c-ai'], ['音乐与生活', '--c-life']];
const asyncTotal = ASYNCS.reduce((t, a) => t + (counts[a[0]] || 0), 0) || 1;
const apct = (c: string) => (((counts[c] || 0) / asyncTotal) * 100).toFixed(1);
const fmt = (d: Date) => d.toISOString().slice(0, 10);
const CAT_SW: Record<string, string> = {
  'UE 剖析': '--c-render', '读渲染': '--accent', 'AI 与认知': '--c-ai', '音乐与生活': '--c-life',
};
const SUB_SW: Record<string, string> = {
  '渲染': '--c-render', '角色': '--c-char', '几何': '--c-engine', '系统': '--c-tool',
};
const swOf = (p: any) => (p.data.sub ? SUB_SW[p.data.sub] : CAT_SW[p.data.cat] || '--accent');
---
<Base>
<main class="wrap" id="home">


  <div class="hero">
    <div class="select-box">
      <span class="corner c-tl" aria-hidden="true"></span><span class="corner c-tr" aria-hidden="true"></span>
      <span class="corner c-bl" aria-hidden="true"></span><span class="corner c-br" aria-hidden="true"></span>
      <h1>一<span class="f">帧</span>之内<span class="en mono">WITHIN ONE FRAME · 16.67 MS</span></h1>
    </div>
    <p class="lead"><strong>16.67 毫秒的预算，够渲染一整个世界。</strong><br>
    主线程跑 UE 源码剖析 —— 渲染、角色、几何与系统框架；异步线程跑深度学习、脑机接口，和管弦乐 ——
    记录踩过的坑、读过的 paper，和帧预算之外的生活。</p>

    <div class="frame" role="img" aria-label="以 GPU 帧时间线呈现的内容分布">
      <div class="frame-head mono">
        <span>本站内容分布 — GPU 轨道以一帧 16.67 ms 计</span>
      </div>
      <div class="track">
        {SUBS.map((s) => (
          <div class="seg" style={`width:${pct(s)}%; background:var(${SUB_SW[s]});`}></div>
        ))}
      </div>
      <div class="track track-async">
        {ASYNCS.map(([c, sw]) => (
          <div class="seg" style={`width:${apct(c)}%; background:var(${sw});`}></div>
        ))}
      </div>
      <div class="legend mono">
        {SUBS.map((s) => (
          <div class="row"><span class="sw" style={`background:var(${SUB_SW[s]});`}></span><b>UE · {s}</b><span class="ms">{ms(s)} ms · {subCounts[s] || 0} 篇</span></div>
        ))}
        {ASYNCS.map(([c, sw]) => (
          <div class="row"><span class="sw" style={`background:var(${sw});`}></span><b>{c}</b><span class="ms">async · {counts[c] || 0} 篇</span></div>
        ))}
      </div>
    </div>
  </div>

  <section>
    <div class="sec-head">
      <h2 id="series">专栏</h2><span class="k mono">SERIES / 04</span>
      <span class="rule"></span>
      <a class="more mono" href="/archive/">归档 →</a>
    </div>
    <div class="cols">
      <a class="col-card" href="/cat/UE 剖析/">
        <div class="col-tag mono"><span class="sw" style="background:var(--c-render);"></span>UE INTERNALS</div>
        <h3>UE 剖析</h3>
        <p>UE 源码级拆解，内分四块：渲染（MegaLights / Nanite / 毛发）、角色（SkinCache / Groom）、几何（网格切割）、系统（Mass / 序列化）。</p>
        <div class="n mono">{counts['UE 剖析'] || 0} 篇 · 渲染 {subCounts['渲染'] || 0} / 角色 {subCounts['角色'] || 0} / 几何 {subCounts['几何'] || 0} / 系统 {subCounts['系统'] || 0}</div>
      </a>
      <a class="col-card" href="/cat/读渲染/">
        <div class="col-tag mono"><span class="sw" style="background:var(--c-tool);"></span>PAPERS</div>
        <h3>读渲染</h3>
        <p>逐段拆解一线大作的渲染分享：Ghost of Yotei 的环境漫反射光照与完整管线流程图。</p>
        <div class="n mono">{cnt("读渲染")}</div>
      </a>
      <a class="col-card" href="/cat/AI 与认知/">
        <div class="col-tag mono"><span class="sw" style="background:var(--c-ai);"></span>AI · MIND</div>
        <h3>AI 与认知</h3>
        <p>从概率论与蒙特卡洛的数学地基，到深度学习与脑机接口实验：用扩散模型从 EEG 里解码大脑。</p>
        <div class="n mono">{cnt("AI 与认知")}</div>
      </a>
      <a class="col-card" href="/cat/音乐与生活/">
        <div class="col-tag mono"><span class="sw" style="background:var(--c-life);"></span>OFF-THREAD</div>
        <h3>音乐与生活</h3>
        <p>异步任务不占帧预算：管弦乐器、听过的音乐会、值得记下来的日子。渲染世界之余，也好好生活。</p>
        <div class="n mono">{cnt("音乐与生活", "随缘更新")}</div>
      </a>
    </div>
  </section>

  <section>
    <div class="sec-head">
      <h2>最新文章</h2><span class="k mono">LATEST</span>
      <span class="rule"></span>
      <a class="more mono" href="/archive/">全部 {posts.length} 篇 →</a>
    </div>
    <div class="posts">
      {latest.map((p) => (
        <a class="post" href={`/posts/${p.id}/`}>
          <span class="sw" style={`background:var(${swOf(p)});`}></span>
          <span class="t">{p.data.title}</span>
          <span class="cat mono">{p.data.sub ? `${p.data.cat} · ${p.data.sub}` : p.data.cat}</span>
          <span class="d mono">{fmt(p.data.date)} · {p.data.mins} min</span>
        </a>
      ))}
    </div>
  </section>

  <section>
    <div class="sec-head">
      <h2>标签</h2><span class="k mono">TAGS</span>
      <span class="rule"></span>
    </div>
    <div class="cvars mono">
      {tagList.map(([tag, n]) => (
        <a class="cvar" href={`/tags/${tag}/`}>{tag} <b>{n}</b></a>
      ))}
    </div>

    <div class="about" id="about">
      <span class="who">Aaron Zhang</span> —— 引擎程序员，正在做一款主机动作游戏。白天在定制的 UE 分支里跟阴影、断肢和帧预算搏斗；晚上训练神经网络，试着从 EEG 信号里解码出大脑看见的东西；周末把时间留给管弦乐和生活。渲染世界是工作，理解世界是爱好——这里是两者的存档。
    </div>
  </section>

</main>
</Base>
