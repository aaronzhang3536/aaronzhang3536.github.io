---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';
const posts = (await getCollection('posts')).sort((a, b) => +b.data.date - +a.data.date);
const counts: Record<string, number> = {};
for (const p of posts) counts[p.data.cat] = (counts[p.data.cat] || 0) + 1;
const cnt = (c: string, empty = '筹备中') => (counts[c] ? `${counts[c]} 篇` : empty);
const fmt = (d: Date) => d.toISOString().slice(0, 10);
const CAT_SW: Record<string, string> = {
  '渲染管线': '--c-render', '引擎定制': '--c-engine', '角色技术': '--c-char',
  '读渲染': '--c-tool', 'AI 与认知': '--c-ai', '音乐与生活': '--c-life',
};
---
<Base>
<main class="wrap" id="home">


  <div class="hero">
    <div class="select-box">
      <span class="corner c-tl" aria-hidden="true"></span><span class="corner c-tr" aria-hidden="true"></span>
      <span class="corner c-bl" aria-hidden="true"></span><span class="corner c-br" aria-hidden="true"></span>
      <h1>一<span class="f">帧</span>之内<span class="en mono">WITHIN ONE FRAME · 16.67 MS</span></h1>
    </div>
    <p class="lead"><strong>16.67 毫秒的预算，够渲染一整个世界。</strong><br>
    主线程跑 UE5 引擎定制、实时渲染与角色技术；异步线程跑深度学习、脑机接口，和管弦乐 ——
    记录踩过的坑、读过的 paper，和帧预算之外的生活。</p>

    <div class="frame" role="img" aria-label="以 GPU 帧时间线呈现的四个内容专栏">
      <div class="frame-head mono">
        <span>本站内容分布 — GPU 轨道以一帧 16.67 ms 计</span>
      </div>
      <div class="track">
        <div class="seg" style="width:38%; background:var(--c-render);"></div>
        <div class="seg" style="width:28%; background:var(--c-engine);"></div>
        <div class="seg" style="width:22%; background:var(--c-char);"></div>
        <div class="seg" style="width:12%; background:var(--c-tool);"></div>
      </div>
      <div class="track track-async">
        <div class="seg" style="width:56%; background:var(--c-ai);"></div>
        <div class="seg" style="width:44%; background:var(--c-life);"></div>
      </div>
      <div class="legend mono">
        <div class="row"><span class="sw" style="background:var(--c-render);"></span><b>渲染管线</b><span class="ms">6.3 ms</span></div>
        <div class="row"><span class="sw" style="background:var(--c-engine);"></span><b>引擎定制</b><span class="ms">4.7 ms</span></div>
        <div class="row"><span class="sw" style="background:var(--c-char);"></span><b>角色技术</b><span class="ms">3.7 ms</span></div>
        <div class="row"><span class="sw" style="background:var(--c-tool);"></span><b>工具链</b><span class="ms">2.0 ms</span></div>
        <div class="row"><span class="sw" style="background:var(--c-ai);"></span><b>AI 与认知</b><span class="ms">async</span></div>
        <div class="row"><span class="sw" style="background:var(--c-life);"></span><b>音乐与生活</b><span class="ms">async</span></div>
      </div>
    </div>
  </div>

  <section>
    <div class="sec-head">
      <h2 id="series">专栏</h2><span class="k mono">SERIES / 06</span>
      <span class="rule"></span>
      <a class="more mono" href="#">全部 →</a>
    </div>
    <div class="cols">
      <a class="col-card" href="/cat/渲染管线/">
        <div class="col-tag mono"><span class="sw" style="background:var(--c-render);"></span>渲染管线</div>
        <h3>MegaLights 实战</h3>
        <p>从距离驱动的 ShadowMethod 切换，到 Shadow LOD Subsystem 的设计与排错 —— 在主机预算内点亮上千盏灯。</p>
        <div class="n mono">{cnt("渲染管线")}</div>
      </a>
      <a class="col-card" href="/cat/角色技术/">
        <div class="col-tag mono"><span class="sw" style="background:var(--c-char);"></span>角色技术</div>
        <h3>断肢系统 Devlog</h3>
        <p>SkeletalMesh 运行时切割：切面几何、凸包生成、UV 稳定性、PhysicsAsset 复用与预生成资产的过期策略。</p>
        <div class="n mono">{cnt("角色技术")}</div>
      </a>
      <a class="col-card" href="/cat/引擎定制/">
        <div class="col-tag mono"><span class="sw" style="background:var(--c-engine);"></span>引擎定制</div>
        <h3>引擎分支维护手记</h3>
        <p>维护一条自己的 UE 分支意味着什么：5.7 → 5.8 的升级合并、编辑器扩展、Outliner 改造与规范落地。</p>
        <div class="n mono">{cnt("引擎定制")}</div>
      </a>
      <a class="col-card" href="/cat/读渲染/">
        <div class="col-tag mono"><span class="sw" style="background:var(--c-tool);"></span>读渲染</div>
        <h3>Paper 精读</h3>
        <p>逐段拆解一线大作的渲染分享：Ghost of Yotei 的 Ambient Diffuse Lighting、八面体烘焙、BVH 与 LOD 的取舍。</p>
        <div class="n mono">{cnt("读渲染")}</div>
      </a>
      <a class="col-card" href="/cat/AI 与认知/">
        <div class="col-tag mono"><span class="sw" style="background:var(--c-ai);"></span>AI 与认知</div>
        <h3>解码大脑</h3>
        <p>深度学习与脑机接口的实验手记：用扩散模型从 EEG 信号里重建所见图像，以及一路读下来的认知科学。</p>
        <div class="n mono">{cnt("AI 与认知")}</div>
      </a>
      <a class="col-card" href="/cat/音乐与生活/">
        <div class="col-tag mono"><span class="sw" style="background:var(--c-life);"></span>音乐与生活</div>
        <h3>主线程之外</h3>
        <p>异步任务不占帧预算：管弦乐器、听过的音乐会、值得记下来的日子。渲染世界之余，也好好生活。</p>
        <div class="n mono">{cnt("音乐与生活", "随缘更新")}</div>
      </a>
    </div>
  </section>

  <section>
    <div class="sec-head">
      <h2>最新文章</h2><span class="k mono">LATEST</span>
      <span class="rule"></span>
      <a class="more mono" href="#">归档 →</a>
    </div>
    <div class="posts">
      {posts.map((p) => (
        <a class="post" href={`/posts/${p.id}/`}>
          <span class="sw" style={`background:var(${CAT_SW[p.data.cat]});`}></span>
          <span class="t">{p.data.title}</span>
          <span class="cat mono">{p.data.cat}</span>
          <span class="d mono">{fmt(p.data.date)} · {p.data.mins} min</span>
        </a>
      ))}
    </div>
  </section>

  <section>
    <div class="sec-head">
      <h2>标签</h2><span class="k mono">TAGS</span>
      <span class="rule"></span>
    </div>
    <div class="cvars mono">
      <a class="cvar" href="#">MegaLights</a>
      <a class="cvar" href="#">VirtualShadowMap</a>
      <a class="cvar" href="#">Nanite</a>
      <a class="cvar" href="#">RayTracing</a>
      <a class="cvar" href="#">Dismemberment</a>
      <a class="cvar" href="#">ChaosCloth</a>
      <a class="cvar" href="#">MLDeformer</a>
      <a class="cvar" href="#">MetaHuman</a>
      <a class="cvar" href="#">Scalability</a>
      <a class="cvar" href="#">EditorTools</a>
      <a class="cvar" href="#">EngineMerge</a>
      <a class="cvar" href="#">SubstancePainter</a>
      <a class="cvar" href="#">DeepLearning</a>
      <a class="cvar" href="#">EEG</a>
      <a class="cvar" href="#">Diffusion</a>
      <a class="cvar" href="#">管弦乐</a>
    </div>

    <div class="about" id="about">
      <span class="who">Aaron Zhang</span> —— 引擎程序员，正在做一款主机动作游戏。白天在定制的 UE 分支里跟阴影、断肢和帧预算搏斗；晚上训练神经网络，试着从 EEG 信号里解码出大脑看见的东西；周末把时间留给管弦乐和生活。渲染世界是工作，理解世界是爱好——这里是两者的存档。
    </div>
  </section>

</main>
</Base>
